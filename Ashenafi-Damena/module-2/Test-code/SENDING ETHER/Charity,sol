pragma solidity ^0.8.20;

contract Contract {
    // Public state variables to store addresses
    address public owner;
    address public charity;

    // Modify the constructor to accept the charity address
    constructor(address _charity) {
        owner = msg.sender;
        charity = _charity;
    }

    // Special function to receive Ether when calldata is empty
    receive() external payable {}

    // Public payable function to tip the owner
    function tip() public payable {
        (bool success, ) = owner.call{value: msg.value}("");
        require(success, "Transfer to owner failed");
    }

    // Function to donate all remaining funds in the contract to the charity
    function donate() public {
        // Get the entire balance of this contract
        uint256 totalBalance = address(this).balance;

        // Ensure there are funds available to donate
        require(totalBalance > 0, "No funds available to donate");

        // Transfer the entire balance to the charity address
        (bool success, ) = charity.call{value: totalBalance}("");
        require(success, "Donation failed");
    }
}